# SaaS Project Management Platform (Workstation) - Environment Variables

# ================================
# Backend Microservices Config
# ================================
# Common JWT Secret used for Auth Service to sign tokens and other services to verify
JWT_SECRET=workstationpm_dev_secret_key

# Set to true to enable OpenAI endpoints (requires valid OPENAI_API_KEY)
ENABLE_AI_FEATURES=false

# OpenAI token for Task Summaries, Subtask suggestions, and Priorities
# WARNING: Keep this secret in production!
OPENAI_API_KEY=your_openai_api_key_here

# Redis Configuration (automatically handled in local docker-compose via dns resolution container naming)
# To run services locally without Docker use:
# REDIS_URL=redis://127.0.0.1:6379

# MongoDB Configuration (handled locally by docker-compose, but useful for manual runs)
# MONGO_URI=mongodb://127.0.0.1:27017/workstationpm

# API Gateway Local URLs
# AUTH_SERVICE_URL=http://localhost:4001
# TASK_SERVICE_URL=http://localhost:4002
# ANALYTICS_SERVICE_URL=http://localhost:4003

# ================================
# Frontend Build Time Config
# ================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:4004
NEXT_PUBLIC_GOOGLE_OAUTH_URL=/api/auth/google
