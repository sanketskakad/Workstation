# =========================
# Node.js / Express
# =========================

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/Jest
coverage/

# Dependency directories
node_modules/

# Optional npm cache directory
.npm
.yarn
.pnpm-store/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Parcel cache
.cache

# Next.js build output
.next/
out/
dist/

# Next.js static files
*.next
.next/cache
.next/server

# Next.js temp files
.next/types

# =========================
# Kubernetes (K8s)
# =========================

# Ignore local K8s manifests that may be generated dynamically
k8s/*.local.yaml
*.local.yaml

# Ignore Helm charts' local packaging
*.tgz

# Ignore Kustomize cache
.kustomize/

# =========================
# IDEs / Editors
# =========================

# VSCode
.vscode/
.history/
*.code-workspace

# JetBrains
.idea/

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# =========================
# Docker
# =========================

# Ignore Docker build files and sensitive configs
docker-compose.override.yml
.docker/
*.dockerfile

# =========================
# Misc / OS Files
# =========================

# npm / yarn / pnpm lock files are usually committed for reproducible builds
# but ignore shrinkwrap if needed
npm-shrinkwrap.json

# Temp files
*.swp
*.swo
*.tmp
*.temp

# =========================
# Testing / Coverage
# =========================

# Jest / Vitest
coverage/
*.test.ts.snap
*.spec.ts.snap

# Cypress
cypress/videos/
cypress/screenshots/

# =========================
# Production Secrets / Keys
# =========================

*.pem
*.key
*.crt
*.p12
*.jks

